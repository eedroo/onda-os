# ─── Firebase ─────────────────────────────────────────────────────────────────
# Vai a console.firebase.google.com → Teu projeto → Configurações → Apps Web
# Copia os valores do objeto firebaseConfig

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=onda-os.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=onda-os
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=onda-os.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
